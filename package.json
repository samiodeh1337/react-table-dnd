{
  "name": "react-table-dnd",
  "version": "2.0.7",
  "type": "module",
  "description": "Sortable table with draggable rows and columns",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "style": "./dist/react-table-dnd.css",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/react-table-dnd.css",
    "./dist/react-table-dnd.css": "./dist/react-table-dnd.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite --config vite.config.docs.ts",
    "build:docs": "vite build --config vite.config.docs.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [
    "react",
    "table",
    "sortable",
    "draggable",
    "draggable table",
    "draggable rows",
    "draggable columns",
    "react table",
    "data grid",
    "row reordering",
    "column reordering"
  ],
  "author": "Sami Odeh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samiodeh1337/react-table-dnd.git"
  },
  "homepage": "https://samiodeh1337.github.io/react-table-dnd/",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "styled-components": "^6.3.11",
    "@eslint/js": "^9.39.4",
    "@tanstack/react-virtual": "^3.13.22",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  }
}
